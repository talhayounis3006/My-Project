# Balkan Food Store - Environment Variables

# Use a secure random string for JWT session tokens
AUTH_SECRET=your-secret-here

# Optional: PostgreSQL Connection String (Required for Vercel/Production persistence)
# Example: postgresql://user:password@hostname:port/database?sslmode=require
# POSTGRES_URL=

# Note: If POSTGRES_URL is not set, the app defaults to local SQLite for development.
